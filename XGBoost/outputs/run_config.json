{
  "input_path": "./data/raw/prime_dataset_model_input_with_purge.csv",
  "output_dir": "XGBoost/outputs",
  "target_col": "Log_NoOfDenguePatients",
  "district_col": "District",
  "date_col": "Date",
  "monthyear_col": "Month-year",
  "split_col": "split",
  "use_district_ohe": true,
  "horizon": 6,
  "use_tuning": true,
  "tuning_iter": 20,
  "random_state": 42,
  "require_purge_rows": true,
  "base_params": {
    "objective": "reg:squarederror",
    "eval_metric": "rmse",
    "n_estimators": 2500,
    "learning_rate": 0.03,
    "max_depth": 4,
    "min_child_weight": 2.0,
    "subsample": 0.85,
    "colsample_bytree": 0.85,
    "gamma": 0.0,
    "reg_alpha": 0.0,
    "reg_lambda": 1.0,
    "tree_method": "hist",
    "n_jobs": -1,
    "random_state": 42,
    "early_stopping_rounds": 100
  }
}